# Copy to deploy/free/.env on the server. Never commit real secrets.
ATLAS_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
ATLAS_IMAGE=atlas-backend:local
ENVIRONMENT=production

# Migration/admin database owner. Keep this secret out of API/worker runtime URLs.
POSTGRES_USER=atlas_admin
POSTGRES_PASSWORD=change-me-long-random-url-safe-password-min-24-chars
POSTGRES_DB=atlas

# Runtime roles created automatically by db-roles. The tenant role is
# NOSUPERUSER/NOBYPASSRLS; the system role is NOSUPERUSER/BYPASSRLS for
# worker/admin tasks that must cross tenant RLS boundaries.
ATLAS_TENANT_DB_USER=atlas_tenant_app
ATLAS_TENANT_DB_PASSWORD=change-me-tenant-runtime-password-min-24-chars
ATLAS_SYSTEM_DB_USER=atlas_system_app
ATLAS_SYSTEM_DB_PASSWORD=change-me-system-runtime-password-min-24-chars

API_KEY_HASH_SECRET=change-me-64-random-hex-chars-generated-with-secrets-token-hex-32
# Optional rotation bridge. Leave empty unless rotating API_KEY_HASH_SECRET.
API_KEY_HASH_SECRET_PREVIOUS=
ALLOWED_HOSTS=api.example.com,127.0.0.1,localhost
CORS_ORIGINS=https://example.com
HSTS_ENABLED=true

# Keep /metrics private. Caddy blocks it publicly; this token is useful for
# direct local scrapes or SSH tunnels.
PROMETHEUS_ALLOWED_CIDRS=127.0.0.1/32,::1/128
PROMETHEUS_BEARER_TOKEN=
PROMETHEUS_EXPENSIVE_DOMAIN_METRICS_ENABLED=false

WEB_CONCURRENCY=2
LOG_LEVEL=INFO
# Behind Caddy all requests can appear from one container IP. Keep the in-app
# limiter off here and use Caddy/Cloudflare rate limits when needed.
RATE_LIMIT_REQUESTS=0
RATE_LIMIT_IN_MEMORY_ENABLED=false
# Required ownership declaration for production rate limiting when in-app
# limiting is disabled.
EDGE_RATE_LIMIT_OWNER=caddy
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Synchronous admin rebuilds through HTTP stay bounded in production.
ADMIN_ALLOW_UNBOUNDED_PROJECTION_REBUILDS=false
ADMIN_MAX_PROJECTION_REBUILD_EVENTS=10000

# ── Hermes crawler ──────────────────────────────────────────────────────────
# REQUIRED in production because hermes-worker is enabled in this stack:
# comma-separated host allowlist for the Hermes server-side fetcher.  This is
# defense-in-depth for SSRF on top of pinned-DNS public-IP validation.  Replace
# the example with the exact domains this deployment is allowed to crawl.
HERMES_ALLOWED_HOSTS=aviation-safety.net,ntsb.gov

# Hermes worker tuning.  Increase batch_limit for higher-throughput crawls;
# keep lease_seconds well above the slowest expected fetch + commit so
# concurrent workers do not race the stale-recovery path.
HERMES_WORKER_SLEEP_SECONDS=5
HERMES_WORKER_BATCH_LIMIT=5
HERMES_WORKER_LEASE_SECONDS=300
HERMES_WORKER_RECOVER_LIMIT=100
