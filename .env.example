# Atlas Backend — environment configuration
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# ── Environment ─────────────────────────────────────────────────────────────
# One of: development | staging | production | test.
# When set to 'production', startup fails fast if API_KEY_HASH_SECRET is missing.
ENVIRONMENT=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Development fallback async URL used by SQLAlchemy (asyncpg driver).
# In production, set TENANT_DATABASE_URL and SYSTEM_DATABASE_URL explicitly.
DATABASE_URL=postgresql+asyncpg://atlas:changeme@localhost:5432/atlas

# Production role split for PostgreSQL RLS hardening.
# TENANT_DATABASE_URL must use the normal request role: NOSUPERUSER NOBYPASSRLS.
# SYSTEM_DATABASE_URL may use a separate system/admin role for migrations, workers,
# and cross-tenant maintenance tasks. Production startup requires both and refuses
# to start if they point to the same URL.
# TENANT_DATABASE_URL=postgresql+asyncpg://atlas_app:changeme@localhost:5432/atlas
# SYSTEM_DATABASE_URL=postgresql+asyncpg://atlas_system:changeme@localhost:5432/atlas

# ── Split-topology (optional) ─────────────────────────────────────────────────
# Set PUBLIC_DATABASE_URL to enable the "fully separate" topology where the
# public Atlas event store and the SMS (tenant) database are physically separate.
# Leave unset to use a single shared database (default for development).
#
# Sync public projections into the SMS DB with: python -m atlas.presentation.cli.ntsb sync-corpus
# Pre-warm the Echo corpus cache after sync with: python -m atlas.presentation.cli.ntsb warm-corpus
#
# PUBLIC_DATABASE_URL=postgresql+asyncpg://atlas_public:changeme@public-db:5432/atlas_public
# PUBLIC_DATABASE_SYNC_URL=postgresql://atlas_public:changeme@public-db:5432/atlas_public
# To migrate the public DB explicitly, run Alembic with:
# ATLAS_MIGRATION_TARGET=public alembic upgrade head

# Sync URL used by Alembic migrations only (psycopg2 driver).
# Default/system/SMS migrations use DATABASE_SYNC_URL.
DATABASE_SYNC_URL=postgresql://atlas:changeme@localhost:5432/atlas

# Passed to the postgres Docker container via docker-compose.yml.
POSTGRES_USER=atlas
POSTGRES_PASSWORD=changeme
POSTGRES_DB=atlas
# Optional production deploy/free role names/passwords. These are used by
# deploy/free/init-db-roles.sh and compose to create separate runtime roles.
# ATLAS_TENANT_DB_USER=atlas_tenant_app
# ATLAS_TENANT_DB_PASSWORD=change-me-tenant-runtime-password
# ATLAS_SYSTEM_DB_USER=atlas_system_app
# ATLAS_SYSTEM_DB_PASSWORD=change-me-system-runtime-password

# ── API key security ────────────────────────────────────────────────────────
# Enables HMAC-SHA256 key hashing. Without this, keys are stored as plain
# SHA-256, which is weaker. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Set in production. Changing it after keys are stored will invalidate all
# existing keys.
# API_KEY_HASH_SECRET=
# Optional bounded cutover bridge. When set, API auth accepts key hashes
# produced by this previous secret as well. New keys still hash with
# API_KEY_HASH_SECRET. Remove after rotation completes.
# API_KEY_HASH_SECRET_PREVIOUS=

# In-process positive-cache for validated API keys. Set TTL to 0 for immediate
# revocation semantics at the cost of one DB lookup per authenticated request.
# Note: 60 is a dev-friendly default. Production startup emits a warning when
# this exceeds 30 seconds (because revoked keys remain valid for up to the TTL
# on every running process). Keep <=5 in high-assurance deployments.
API_KEY_CACHE_TTL_SECONDS=60
API_KEY_CACHE_MAX_ENTRIES=10000

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser cross-origin requests.
# Leave empty to block all cross-origin requests (safe default for APIs).
# Must not contain * (credentials are enabled).
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
# CORS_ORIGINS=

# ── Easy security hardening ────────────────────────────────────────────────
# Comma-separated hosts accepted by Host-header validation. Development uses
# wildcard by default; production fails startup unless this is explicit.
# Example: ALLOWED_HOSTS=api.example.com,127.0.0.1,localhost
ALLOWED_HOSTS=*

# Interactive Swagger/ReDoc/OpenAPI docs. Default is enabled outside production
# and disabled in production. Keep false on public deployments.
# API_DOCS_ENABLED=false

SECURITY_HEADERS_ENABLED=true
# Enable only once the service is served over HTTPS.
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000

# ── Ingestion limits ────────────────────────────────────────────────────────
MAX_CLAIMS_PER_REQUEST=500
MAX_RAW_PAYLOAD_BYTES=1048576
REQUEST_BODY_OVERHEAD_BYTES=65536

# ── Rate limiting ─────────────────────────────────────────────────────────
# Set RATE_LIMIT_REQUESTS=0 to disable the in-process limiter and rely on infrastructure.
# In production, the in-process limiter is disabled unless explicitly opted in.
# Prefer infrastructure/API-gateway or Redis-backed rate limiting for production.
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_IN_MEMORY_ENABLED=true

# ── Admin maintenance safety ────────────────────────────────────────────────
# Production refuses unlimited projection rebuilds through HTTP unless this is
# explicitly enabled for a maintenance window. Keep false for normal operation.
ADMIN_ALLOW_UNBOUNDED_PROJECTION_REBUILDS=false
ADMIN_MAX_PROJECTION_REBUILD_EVENTS=10000

# ── Outbox worker ───────────────────────────────────────────────────────────
# Maximum delivery attempts before an event is dead-lettered.
OUTBOX_MAX_ATTEMPTS=5
# Minutes before a PROCESSING lock is considered stale (crashed worker recovery).
OUTBOX_STALE_LOCK_MINUTES=10

# ── Database connection pool ────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600
# Set true when using PgBouncer in transaction-pooling mode.
DB_USE_NULL_POOL=false

# ── Echo cross-reference ──────────────────────────────────────────────────────
# How long (seconds) to cache the public precedent corpus in memory between
# cross-reference runs. Set to 0 to reload on every run.
ECHO_CORPUS_CACHE_TTL_SECONDS=3600

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Exposes /metrics for Prometheus. Keep it private with CIDR allow-listing
# and/or a static bearer token for your Prometheus scraper.
PROMETHEUS_METRICS_ENABLED=true
# Includes DB-backed domain gauges such as outbox status and open conflicts.
PROMETHEUS_DOMAIN_METRICS_ENABLED=true
# Cache DB-backed gauges so scrapes do not repeatedly count large tables.
PROMETHEUS_DOMAIN_METRICS_TTL_SECONDS=15
PROMETHEUS_EXPENSIVE_DOMAIN_METRICS_ENABLED=false
# Comma-separated CIDRs allowed to scrape /metrics. Defaults to localhost only.
# For Kubernetes, set this to your Prometheus pod/service CIDR or enforce the
# same restriction at the ingress/network-policy layer. Never use 0.0.0.0/0
# on an internet-facing deployment.
PROMETHEUS_ALLOWED_CIDRS=127.0.0.1/32,::1/128
# Optional static token. Scrapers send: Authorization: Bearer <token>.
# PROMETHEUS_BEARER_TOKEN=

# ── Gunicorn production wrapper ─────────────────────────────────────────────
# Defaults to (2 * CPU cores) + 1 when unset. For small containers, set explicitly.
# WEB_CONCURRENCY=2
GUNICORN_KEEPALIVE_SECONDS=55
GUNICORN_TIMEOUT_SECONDS=60
GUNICORN_GRACEFUL_TIMEOUT_SECONDS=30
GUNICORN_MAX_REQUESTS=10000
GUNICORN_MAX_REQUESTS_JITTER=1000

# ── Curator override source ─────────────────────────────────────────────────
# Fixed UUID seeded by migration 003. Do not change after the first migration.
CURATOR_OVERRIDE_SOURCE_ID=00000000-0000-0000-0000-000000000001
CURATOR_OVERRIDE_SOURCE_NAME=CuratorOverride

# ── Hermes crawler ──────────────────────────────────────────────────────────
# Comma-separated host allowlist for the Hermes server-side fetcher.  When
# set, every fetch target hostname must match an entry (exact host, or a
# parent domain — entry ``example.com`` covers ``news.example.com``).
# This is defense-in-depth for SSRF on top of pinned-DNS public-IP validation:
# a DNS-rebinding attack must also target a hostname Atlas has explicitly
# trusted.  Leave empty only in development or when the Hermes worker is not
# running; production Hermes workers fail startup without this value.
#   Example: HERMES_ALLOWED_HOSTS=aviation-safety.net,ntsb.gov,asn.flightsafety.org
HERMES_ALLOWED_HOSTS=

# Hermes worker tuning.  The defaults are sane for low-volume crawl loads.
HERMES_WORKER_SLEEP_SECONDS=5
HERMES_WORKER_BATCH_LIMIT=5
HERMES_WORKER_LEASE_SECONDS=300
HERMES_WORKER_RECOVER_LIMIT=100
